# Environment Variables
# IG Demo Account Credentials
IG_USERNAME=
IG_PASSWORD=
IG_API_KEY=
IG_ACCOUNT_ID=Z3MJKY
IG_API_ENDPOINT=https://demo-api.ig.com/gateway/deal

# BrainJar Settings
BRAIN_PORT=3001
BRAIN_API_PORT=8000
BRAIN_PYTHON_SCRIPT=brain_engine.py

# Tick Recording
TICK_DATA_DIR=./data/ticks
TICK_CSV_ENABLED=true
TICK_TIMEFRAMES=tick,1s,2s,1h

# Learning/Memory
LEARNING_ENABLED=true
LEARNING_MEMORY_FILE=./data/brain_memory.json
MAX_MEMORY_ENTRIES=10000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/brainjar.log